{
  "expo": {
    "backgroundColor": "#0A0F1E",
    "name": "NutriLens",
    "slug": "nutrilens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutrilens",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0F1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cesk.nutrilens",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Kamera, barkod tarama ve yemek fotoğrafı çekerek analiz yapabilmeniz için kullanılır.",
        "NSPhotoLibraryUsageDescription": "Yemek fotoğraflarını seçip analiz edebilmeniz için fotoğraf arşivinize erişim gereklidir.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
